# TEMPLATE ONLY — this file is committed to git, so it must contain NO real key.
# Copy it to a .env at the repo root (git-ignored) and put your real key there.
# Every track's key loader searches the repo-root .env for GEMINI_API_KEY.
# Recommended: GEMINI_API_KEY (Gemini SDK scope) rather than the generic GOOGLE_API_KEY.
# Restrict the key in Google AI Studio. NEVER paste a real key into this .env.example.
GEMINI_API_KEY=your_api_key_here
